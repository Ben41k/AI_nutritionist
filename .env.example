# Скопируйте в apps/api/.env и заполните значения.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dietitian"
JWT_SECRET="replace-with-long-random-string"
CLIENT_ORIGIN="http://localhost:5173"

OPENROUTER_API_KEY=""
OPENROUTER_CHAT_MODEL="google/gemma-3n-e2b-it:free"
# OPENROUTER_CHAT_FALLBACK_MODELS="google/gemma-3-4b-it:free,meta-llama/llama-3.2-3b-instruct:free"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-large"
# OPENROUTER_EMBEDDING_FALLBACK_MODELS="qwen/qwen3-embedding-8b,openai/text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# Опционально: OpenRouter просит Referer/Title для части провайдеров (без этого эмбеддинги могут отклоняться).
# По умолчанию Referer = CLIENT_ORIGIN, Title = "AI Nutritionist".
# OPENROUTER_HTTP_REFERER="https://example.com"
# OPENROUTER_X_TITLE="My App"

# Опционально: при отказе OpenRouter на эмбеддингах — повтор через Gemini (Google AI).
# GEMINI_API_KEY=""
# GOOGLE_API_KEY=""  # альтернативное имя переменной
# GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Первый зарегистрированный email с этим значением получит роль ADMIN (опционально).
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"

# API
PORT=3001
# API_RATE_LIMIT_MAX=400
