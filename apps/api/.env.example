DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dietitian"
JWT_SECRET="replace-with-long-random-string"
CLIENT_ORIGIN="http://localhost:5173"
PORT=3001

# Лимит HTTP-запросов с одного IP (в минуту). При 429 в браузере можно поднять, например 800.
# API_RATE_LIMIT_MAX=400

OPENROUTER_API_KEY=""
OPENROUTER_CHAT_MODEL="google/gemma-3n-e2b-it:free"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# Опционально: Referer/Title для OpenRouter (часть провайдеров требует).
# OPENROUTER_HTTP_REFERER="https://example.com"
# OPENROUTER_X_TITLE="My App"

# Опционально: при отказе OpenRouter на эмбеддингах — повтор через Gemini (Google AI).
# GEMINI_API_KEY=""
# GOOGLE_API_KEY=""  # альтернативное имя
# GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
