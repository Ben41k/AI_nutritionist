DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dietitian"
JWT_SECRET="replace-with-long-random-string"
CLIENT_ORIGIN="http://localhost:5173"
PORT=3001

# Лимит HTTP-запросов с одного IP (в минуту). При 429 в браузере можно поднять, например 800.
# API_RATE_LIMIT_MAX=400

OPENROUTER_API_KEY=""
OPENROUTER_CHAT_MODEL="google/gemma-3n-e2b-it:free"
# Через запятую: запасные чат-модели при ошибке основной (порядок важен). По умолчанию в коде:
# google/gemma-3-4b-it:free, google/gemma-3-12b-it:free, google/gemma-3-27b-it:free,
# meta-llama/llama-3.3-70b-instruct:free, meta-llama/llama-3.2-3b-instruct:free, nousresearch/hermes-3-llama-3.1-405b:free
# OPENROUTER_CHAT_FALLBACK_MODELS=""
# Основной эмбеддинг (OpenRouter slug). Рекомендуется openai/text-embedding-3-large для текста EN/не-EN.
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-large"
# Через запятую: запасные модели, если основная недоступна (порядок важен). По умолчанию в коде:
# qwen/qwen3-embedding-8b, openai/text-embedding-3-small, qwen/qwen3-embedding-4b, qwen/qwen3-embedding-0.6b, mistralai/codestral-embed-2505
# OPENROUTER_EMBEDDING_FALLBACK_MODELS=""
EMBEDDING_DIMENSIONS=1536

# Опционально: Referer/Title для OpenRouter (часть провайдеров требует).
# OPENROUTER_HTTP_REFERER="https://example.com"
# OPENROUTER_X_TITLE="My App"

# Опционально: при отказе OpenRouter на эмбеддингах — повтор через Gemini (Google AI).
# GEMINI_API_KEY=""
# GOOGLE_API_KEY=""  # альтернативное имя
# GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
