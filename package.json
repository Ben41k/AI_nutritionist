{
  "name": "ai-nutritionist",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w apps/web\" \"npm run dev -w apps/api\"",
    "build": "npm run build -w apps/web && npm run build -w apps/api",
    "lint": "npm run lint -w apps/web && npm run lint -w apps/api",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,js,json,css,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": "eslint --config apps/web/eslint.config.js --fix --max-warnings 0",
    "apps/api/**/*.ts": "eslint --config apps/api/eslint.config.js --fix --max-warnings 0",
    "apps/**/*.{json,css,md}": "prettier --write"
  }
}
